{
  "name": "headcount",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "seed": "pnpm --filter @headcount/orchestrator seed",
    "orchestrator:dev": "pnpm --filter @headcount/orchestrator dev",
    "dashboard:dev": "pnpm --filter @headcount/dashboard dev"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
